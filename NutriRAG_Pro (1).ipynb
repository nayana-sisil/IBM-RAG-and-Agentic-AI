    "                f\"({r['pct']}% of {r['drv']} {unit} DRV)\", body_style))\n",
    "    if not low and not high:\n",
    "        story.append(Paragraph(\"✅ All tracked nutrients are within recommended ranges.\", body_style))\n",
    "\n",
