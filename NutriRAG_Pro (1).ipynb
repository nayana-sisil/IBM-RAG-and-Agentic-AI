    "            ])\n",
    "        mt = Table(meal_data, colWidths=[0.6*inch, 2.5*inch, 1.0*inch, 0.8*inch, 0.8*inch, 0.8*inch])\n",
    "        mt.setStyle(TableStyle([\n",
    "            (\"BACKGROUND\", (0,0), (-1,0), TEAL),\n",
    "            (\"TEXTCOLOR\",  (0,0), (-1,0), colors.white),\n",
    "            (\"FONTNAME\",   (0,0), (-1,0), \"Helvetica-Bold\"),\n",
    "            (\"GRID\",       (0,0), (-1,-1), 0.5, colors.lightgrey),\n",
    "            (\"FONTSIZE\",   (0,0), (-1,-1), 9),\n",
    "            (\"PADDING\",    (0,0), (-1,-1), 4),\n",
    "            (\"ROWBACKGROUNDS\", (0,1), (-1,-1), [colors.white, LIGHT]),\n",
    "            (\"VALIGN\",     (0,0), (-1,-1), \"TOP\"),\n",
    "        ]))\n",
    "        story.append(mt)\n",
    "    else:\n",
    "        story.append(Paragraph(\"No meals logged yet.\", body_style))\n",
    "\n",
    "    # ── Deficiency analysis ──\n",
    "    story.append(Spacer(1, 0.15*inch))\n",
    "    story.append(Paragraph(\"Deficiency Analysis\", h2_style))\n",
    "    low  = [r for r in deficiencies if r[\"status\"]==\"LOW\"]\n",
    "    high = [r for r in deficiencies if r[\"status\"]==\"HIGH\"]\n",
    "    if low:\n",
    "        story.append(Paragraph(\n",
    "            \"<b>Nutrients below 60% of DRV (consider increasing intake):</b>\", body_style))\n",
