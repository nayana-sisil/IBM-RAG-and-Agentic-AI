   "source": [
    "# 🥗 NutriRAG Pro — Multimodal Nutrition Analyzer\n",
    "Upload a food photo → Gemini Vision identifies foods → ChromaDB retrieves USDA nutrition facts → LLM generates a personalized, cited analysis.\n",
    "\n",
    "> **Before running:** Paste your Gemini API key in Cell 2."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-1-install",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1 — Install all required packages (latest versions, no pins)\n",
    "!pip install -q \\\n",
    "    google-genai \\\n",
    "    langchain-core \\\n",
    "    langchain-google-genai \\\n",
    "    langchain-community \\\n",
    "    chromadb \\\n",
    "    reportlab \\\n",
    "    plotly \\\n",
    "    ipywidgets \\\n",
    "    Pillow \\\n",
    "    pandas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2-imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Imports and API key configuration\n",
    "import io, os, json, datetime, base64, warnings\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "from PIL import Image\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, HTML, clear_output\n",
    "\n",
    "# Google GenAI — new SDK (google.generativeai is deprecated)\n",
    "from google import genai\n",
    "from google.genai import types\n",
    "\n",
    "# LangChain — correct 2025/2026 import paths\n",
    "from langchain_core.documents import Document\n",
    "from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder\n",
    "from langchain_core.output_parsers import StrOutputParser\n",
    "from langchain_core.runnables.history import RunnableWithMessageHistory\n",
    "from langchain_community.vectorstores import Chroma\n",
    "from langchain_community.chat_message_histories import ChatMessageHistory\n",
    "from langchain_google_genai import GoogleGenerativeAI, GoogleGenerativeAIEmbeddings\n",
    "\n",
    "# ReportLab for PDF generation\n",
    "from reportlab.lib.pagesizes import letter\n",
    "from reportlab.lib import colors\n",
    "from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle\n",
    "from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer\n",
    "from reportlab.lib.units import inch\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ── API KEY ── paste your Gemini key here ──────────────────────────\n",
    "API_KEY = \"YOUR_GEMINI_API_KEY_HERE\"\n",
    "# ──────────────────────────────────────────────────────────────────\n",
    "\n",
    "# Initialise the new google-genai client\n",
    "gemini_client = genai.Client(api_key=API_KEY)\n",
    "\n",
    "# LangChain LLM wrapper (uses same key)\n",
    "os.environ[\"GOOGLE_API_KEY\"] = API_KEY\n",
    "llm = GoogleGenerativeAI(model=\"gemini-2.0-flash\", temperature=0.3)\n",
    "embeddings = GoogleGenerativeAIEmbeddings(model=\"models/embedding-001\")\n",
    "\n",
    "# ── Global session state ───────────────────────────────────────────\n",
    "session = {\n",
    "    \"profile\": {\n",
    "        \"name\": \"User\", \"age\": 25, \"weight_kg\": 70.0,\n",
    "        \"height_cm\": 170.0, \"sex\": \"male\",\n",
    "        \"goal\": \"maintenance\", \"activity_level\": \"moderate\"\n",
    "    },\n",
    "    \"daily_log\": [],       # list of meal dicts\n",
    "    \"detected_foods\": \"\",  # last identified foods string\n",
    "    \"last_sources\": []     # list of retrieved USDA source dicts\n",
    "}\n",
    "\n",
    "# ── Conversation memory store ──────────────────────────────────────\n",
    "store = {}\n",
    "def get_session_history(session_id: str) -> ChatMessageHistory:\n",
    "    if session_id not in store:\n",
    "        store[session_id] = ChatMessageHistory()\n",
    "    # Keep last 16 messages to avoid context overflow\n",
    "    if len(store[session_id].messages) > 16:\n",
    "        store[session_id].messages = store[session_id].messages[-16:]\n",
    "    return store[session_id]\n",
    "\n",
    "print(\"✅ Imports and configuration complete.\")"
   ]
  },
