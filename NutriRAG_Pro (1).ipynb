   "source": [
    "# Cell 4 — Build ChromaDB vector store from USDA data\n",
    "# Each food row becomes a LangChain Document with nutrient data in its text\n",
    "\n",
    "def row_to_doc(row):\n",
    "    \"\"\"Convert a DataFrame row to a LangChain Document for embedding.\"\"\"\n",
    "    content = (\n",
    "        f\"{row['food_name']} ({row['category']}): \"\n",
    "        f\"{row['calories']} kcal, protein {row['protein_g']}g, \"\n",
    "        f\"carbs {row['carbs_g']}g, fat {row['fat_g']}g, \"\n",
    "        f\"fiber {row['fiber_g']}g, sugar {row['sugar_g']}g, \"\n",
    "        f\"sodium {row['sodium_mg']}mg, vitamin C {row['vitamin_c_mg']}mg, \"\n",
    "        f\"calcium {row['calcium_mg']}mg, iron {row['iron_mg']}mg. \"\n",
    "        f\"Source: {row['source']}.\"\n",
    "    )\n",
    "    return Document(\n",
    "        page_content=content,\n",
    "        metadata={\n",
    "            \"fdc_id\": str(row[\"fdc_id\"]),\n",
    "            \"food_name\": row[\"food_name\"],\n",
    "            \"category\": row[\"category\"],\n",
    "            \"source\": row[\"source\"],\n",
    "            \"calories\": float(row[\"calories\"]),\n",
    "            \"protein_g\": float(row[\"protein_g\"]),\n",
    "            \"carbs_g\": float(row[\"carbs_g\"]),\n",
    "            \"fat_g\": float(row[\"fat_g\"]),\n",
    "            \"fiber_g\": float(row[\"fiber_g\"]),\n",
    "            \"sodium_mg\": float(row[\"sodium_mg\"]),\n",
    "            \"vitamin_c_mg\": float(row[\"vitamin_c_mg\"]),\n",
    "            \"calcium_mg\": float(row[\"calcium_mg\"]),\n",
    "            \"iron_mg\": float(row[\"iron_mg\"]),\n",
    "        }\n",
    "    )\n",
    "\n",
    "# Build document list\n",
    "docs = [row_to_doc(row) for _, row in df_foods.iterrows()]\n",
    "print(f\"Embedding {len(docs)} food documents into ChromaDB…\")\n",
    "\n",
    "# Create (or overwrite) the Chroma vector store — no .persist() needed in latest version\n",
    "vectorstore = Chroma.from_documents(\n",
    "    documents=docs,\n",
    "    embedding=embeddings,\n",
    "    persist_directory=\"./nutrition_db\"\n",
    ")\n",
    "\n",
    "# Retriever returns top-5 matches by cosine similarity\n",
    "retriever = vectorstore.as_retriever(search_kwargs={\"k\": 5})\n",
    "\n",
    "print(\"✅ ChromaDB vector store ready. Retriever configured (k=5).\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-5-profile",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5 — User profile, TDEE calculator, daily tracker, and WHO targets\n",
    "\n",
    "# ── WHO Daily Reference Values ─────────────────────────────────────\n",
    "WHO_DRV = {\n",
    "    \"calories\":    2000.0,   # kcal (general adult)\n",
    "    \"protein_g\":   50.0,     # g\n",
    "    \"carbs_g\":     260.0,    # g\n",
    "    \"fat_g\":       65.0,     # g\n",
    "    \"fiber_g\":     25.0,     # g\n",
    "    \"sugar_g\":     50.0,     # g (added sugars upper limit)\n",
    "    \"sodium_mg\":   2000.0,   # mg (upper limit)\n",
    "    \"vitamin_c_mg\":90.0,     # mg\n",
    "    \"calcium_mg\":  1000.0,   # mg\n",
    "    \"iron_mg\":     8.0,      # mg (male); 18 mg for pre-menopausal female\n",
    "}\n",
    "\n",
    "# ── TDEE / calorie target calculator ──────────────────────────────\n",
    "ACTIVITY_MULTIPLIERS = {\n",
    "    \"sedentary\":   1.2,\n",
    "    \"light\":       1.375,\n",
    "    \"moderate\":    1.55,\n",
    "    \"active\":      1.725,\n",
    "    \"very_active\": 1.9,\n",
    "}\n",
    "\n",
    "GOAL_ADJUSTMENTS = {\n",
    "    \"weight_loss\":   -500,\n",
    "    \"maintenance\":    0,\n",
    "    \"muscle_gain\":   +500,\n",
    "}\n",
    "\n",
    "def calculate_tdee(profile: dict) -> dict:\n",
    "    \"\"\"Mifflin-St Jeor BMR → TDEE → personalised daily targets.\"\"\"\n",
    "    w = profile[\"weight_kg\"]\n",
    "    h = profile[\"height_cm\"]\n",
    "    a = profile[\"age\"]\n",
    "\n",
    "    # BMR (sex-specific)\n",
    "    if profile[\"sex\"].lower() == \"male\":\n",
    "        bmr = 10 * w + 6.25 * h - 5 * a + 5\n",
    "    else:\n",
    "        bmr = 10 * w + 6.25 * h - 5 * a - 161\n",
    "\n",
    "    activity = ACTIVITY_MULTIPLIERS.get(profile[\"activity_level\"], 1.55)\n",
    "    tdee = bmr * activity\n",
    "    target_cal = tdee + GOAL_ADJUSTMENTS.get(profile[\"goal\"], 0)\n",
    "\n",
    "    # Macro split: 30% protein, 40% carbs, 30% fat\n",
    "    target_protein = round(target_cal * 0.30 / 4, 1)   # 4 kcal/g\n",
    "    target_carbs   = round(target_cal * 0.40 / 4, 1)\n",
    "    target_fat     = round(target_cal * 0.30 / 9, 1)   # 9 kcal/g\n",
    "\n",
    "    return {\n",
    "        \"bmr\": round(bmr),\n",
    "        \"tdee\": round(tdee),\n",
    "        \"target_calories\": round(target_cal),\n",
    "        \"target_protein_g\": target_protein,\n",
    "        \"target_carbs_g\": target_carbs,\n",
    "        \"target_fat_g\": target_fat,\n",
    "    }\n",
    "\n",
    "# ── Daily log helpers ──────────────────────────────────────────────\n",
    "NUTRIENT_KEYS = [\"calories\",\"protein_g\",\"carbs_g\",\"fat_g\",\n",
    "                 \"fiber_g\",\"sugar_g\",\"sodium_mg\",\"vitamin_c_mg\",\n",
    "                 \"calcium_mg\",\"iron_mg\"]\n",
    "\n",
    "def get_daily_totals() -> dict:\n",
    "    \"\"\"Sum all logged nutrients for today's session.\"\"\"\n",
    "    totals = {k: 0.0 for k in NUTRIENT_KEYS}\n",
    "    for meal in session[\"daily_log\"]:\n",
    "        for k in NUTRIENT_KEYS:\n",
    "            totals[k] += meal[\"nutrients\"].get(k, 0.0)\n",
    "    return totals\n",
    "\n",
    "def check_deficiencies() -> list:\n",
    "    \"\"\"Compare today's totals vs WHO DRV; return list of status dicts.\"\"\"\n",
    "    totals = get_daily_totals()\n",
    "    results = []\n",
    "    for k, drv in WHO_DRV.items():\n",
    "        val = totals.get(k, 0.0)\n",
    "        pct = (val / drv * 100) if drv > 0 else 0\n",
    "        if k == \"sodium_mg\":      # sodium: HIGH is bad\n",
    "            status = \"HIGH\" if val > drv else (\"OK\" if val > drv * 0.5 else \"LOW\")\n",
    "        elif k == \"sugar_g\":      # sugar: HIGH is bad\n",
    "            status = \"HIGH\" if val > drv else \"OK\"\n",
    "        else:\n",
    "            status = \"LOW\" if pct < 60 else (\"OK\" if pct <= 120 else \"HIGH\")\n",
    "        results.append({\"nutrient\": k, \"consumed\": round(val,1),\n",
    "                        \"drv\": drv, \"pct\": round(pct,1), \"status\": status})\n",
    "    return results\n",
    "\n",
    "# Quick test with default profile\n",
    "tdee_info = calculate_tdee(session[\"profile\"])\n",
    "print(\"✅ Profile & tracker ready.\")\n",
    "print(f\"   BMR: {tdee_info['bmr']} kcal | TDEE: {tdee_info['tdee']} kcal | \"\n",
    "      f\"Target: {tdee_info['target_calories']} kcal\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-6-rag",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6 — RAG Pipeline: Vision → Retrieve → Generate → Log\n",
    "\n",
    "# ── 1. Food identification via Gemini Vision ───────────────────────\n",
    "def identify_foods(pil_image: Image.Image) -> str:\n",
    "    \"\"\"Send image to Gemini 2.0 Flash and get a food list.\"\"\"\n",
    "    buf = io.BytesIO()\n",
    "    pil_image.save(buf, format=\"JPEG\")\n",
    "    img_bytes = buf.getvalue()\n",
    "\n",
    "    response = gemini_client.models.generate_content(\n",
    "        model=\"gemini-2.0-flash\",\n",
    "        contents=[\n",
    "            types.Part.from_bytes(data=img_bytes, mime_type=\"image/jpeg\"),\n",
    "            (\"List every distinct food item visible in this image. \"\n",
    "             \"Be specific (e.g. 'grilled chicken breast' not just 'chicken'). \"\n",
    "             \"Return ONLY a comma-separated list, nothing else.\")\n",
    "        ]\n",
    "    )\n",
    "    foods = response.text.strip()\n",
    "    session[\"detected_foods\"] = foods\n",
    "    return foods\n",
    "\n",
    "# ── 2. ChromaDB retrieval ──────────────────────────────────────────\n",
    "def retrieve(query: str) -> tuple[str, list]:\n",
    "    \"\"\"Retrieve top-5 matching USDA docs; return (context_str, sources).\"\"\"\n",
    "    results = retriever.invoke(query)\n",
    "    context_parts = []\n",
    "    sources = []\n",
    "    for doc in results:\n",
    "        context_parts.append(doc.page_content)\n",
    "        sources.append({\n",
    "            \"food\":   doc.metadata.get(\"food_name\", \"?\"),\n",
    "            \"source\": doc.metadata.get(\"source\", \"?\"),\n",
    "            \"cal\":    doc.metadata.get(\"calories\", 0),\n",
    "        })\n",
    "    session[\"last_sources\"] = sources\n",
    "    return \"\\n\".join(context_parts), sources\n",
    "\n",
    "# ── 3. RAG prompt & chain ─────────────────────────────────────────\n",
    "RAG_PROMPT = ChatPromptTemplate.from_messages([\n",
    "    (\"system\",\n",
    "     \"\"\"You are NutriRAG Pro, a certified nutrition analysis assistant.\n",
    "\n",
    "USER PROFILE:\n",
    "  Name: {name} | Age: {age} | Sex: {sex}\n",
    "  Weight: {weight_kg} kg | Height: {height_cm} cm\n",
    "  Goal: {goal} | Activity: {activity_level}\n",
    "  Daily calorie target: {target_calories} kcal | Protein target: {target_protein_g} g\n",
    "\n",
    "TODAY'S RUNNING TOTALS (so far):\n",
    "  Calories: {eaten_cal} kcal | Protein: {eaten_protein} g | Carbs: {eaten_carbs} g | Fat: {eaten_fat} g\n",
    "\n",
    "DETECTED FOODS IN IMAGE: {detected_foods}\n",
    "\n",
    "RETRIEVED USDA NUTRITION DATA:\n",
    "{context}\n",
    "\n",
    "RULES:\n",
    "1. ONLY use the retrieved USDA data above — do not invent nutrition facts.\n",
    "2. Cite EVERY numeric fact with (Source: USDA #XXXXX) from the retrieved data.\n",
    "3. Personalise advice to the user's goal and daily remaining budget.\n",
    "4. Respond in this exact format:\n",
    "   🍽️ Foods Identified: ...\n",
    "   📊 Calorie Breakdown: (item by item with source citations)\n",
    "   🔢 Total Estimated Calories: X kcal\n",
    "   💪 Macros: Protein Xg | Carbs Xg | Fat Xg\n",
    "   🎯 Goal Check: (how this meal fits user's daily target)\n",
    "   💡 Tip: (one personalised advice sentence)\n",
    "   📚 Sources: (list all USDA IDs used)\n",
    "   ⚠️ Disclaimer: Estimates assume 100g portions unless image suggests otherwise.\"\"\"),\n",
    "    MessagesPlaceholder(variable_name=\"chat_history\"),\n",
    "    (\"human\", \"{question}\"),\n",
    "])\n",
    "\n",
    "# Chain: prompt → LLM → parse to string\n",
    "rag_chain = RAG_PROMPT | llm | StrOutputParser()\n",
    "\n",
    "# Wrap with persistent message history\n",
    "chain_with_history = RunnableWithMessageHistory(\n",
    "    rag_chain,\n",
    "    get_session_history,\n",
    "    input_messages_key=\"question\",\n",
    "    history_messages_key=\"chat_history\",\n",
    ")\n",
    "\n",
    "# ── 4. Aggregate nutrition from retrieved docs ─────────────────────\n",
    "def aggregate_nutrients_from_docs(docs_list) -> dict:\n",
    "    \"\"\"Sum nutrient metadata from retrieved documents (assumes 100 g each).\"\"\"\n",
    "    totals = {k: 0.0 for k in NUTRIENT_KEYS}\n",
    "    for doc in docs_list:\n",
    "        m = doc.metadata\n",
    "        for k in NUTRIENT_KEYS:\n",
    "            totals[k] += m.get(k, 0.0)\n",
    "    return {k: round(v, 1) for k, v in totals.items()}\n",
    "\n",
    "# ── 5. Main orchestrator ───────────────────────────────────────────\n",
    "def run_rag(image: Image.Image, question: str) -> str:\n",
    "    \"\"\"Full pipeline: vision → retrieve → generate → log meal.\"\"\"\n",
    "    # Step A: identify foods\n",
    "    foods = identify_foods(image)\n",
    "\n",
    "    # Step B: retrieve matching USDA docs\n",
    "    context, sources = retrieve(foods)\n",
    "\n",
    "    # Step C: build dynamic profile vars\n",
    "    p = session[\"profile\"]\n",
    "    tdee = calculate_tdee(p)\n",
    "    totals = get_daily_totals()\n",
    "\n",
    "    # Step D: invoke chain with memory\n",
    "    answer = chain_with_history.invoke(\n",
    "        {\n",
    "            \"question\": question or \"Analyse the nutritional content of this meal.\",\n",
    "            \"context\": context,\n",
    "            \"detected_foods\": foods,\n",
    "            \"name\": p[\"name\"], \"age\": p[\"age\"], \"sex\": p[\"sex\"],\n",
    "            \"weight_kg\": p[\"weight_kg\"], \"height_cm\": p[\"height_cm\"],\n",
    "            \"goal\": p[\"goal\"], \"activity_level\": p[\"activity_level\"],\n",
    "            \"target_calories\": tdee[\"target_calories\"],\n",
    "            \"target_protein_g\": tdee[\"target_protein_g\"],\n",
    "            \"eaten_cal\": totals[\"calories\"],\n",
    "            \"eaten_protein\": totals[\"protein_g\"],\n",
    "            \"eaten_carbs\": totals[\"carbs_g\"],\n",
    "            \"eaten_fat\": totals[\"fat_g\"],\n",
    "        },\n",
    "        config={\"configurable\": {\"session_id\": \"main\"}}\n",
    "    )\n",
    "\n",
    "    # Step E: log meal to daily tracker using retrieved nutrient data\n",
    "    raw_docs = retriever.invoke(foods)  # re-retrieve to get Document objects\n",
    "    meal_nutrients = aggregate_nutrients_from_docs(raw_docs)\n",
    "    session[\"daily_log\"].append({\n",
    "        \"time\": datetime.datetime.now().strftime(\"%H:%M\"),\n",
    "        \"food_names\": foods,\n",
    "        \"nutrients\": meal_nutrients,\n",
    "    })\n",
    "\n",
    "    return answer\n",
    "\n",
    "print(\"✅ RAG pipeline ready (vision + retrieval + generation + logging).\")"
   ]
  },
