    "# Cell 7 — PDF Report Generator using ReportLab\n",
    "\n",
    "def generate_pdf_report(filename=\"nutrition_report.pdf\") -> str:\n",
    "    \"\"\"Generate a professional nutrition report and return the file path.\"\"\"\n",
    "    doc = SimpleDocTemplate(filename, pagesize=letter,\n",
    "                            topMargin=0.75*inch, bottomMargin=0.75*inch)\n",
    "    styles = getSampleStyleSheet()\n",
    "    story = []\n",
    "\n",
    "    # ── Colour palette ──\n",
    "    BLUE  = colors.HexColor(\"#0f4c75\")\n",
    "    TEAL  = colors.HexColor(\"#1D9E75\")\n",
    "    LIGHT = colors.HexColor(\"#f0f7ff\")\n",
    "    RED   = colors.HexColor(\"#d9534f\")\n",
    "\n",
    "    # ── Title ──\n",
    "    title_style = ParagraphStyle(\"Title\", parent=styles[\"Title\"],\n",
    "                                 textColor=BLUE, fontSize=20, spaceAfter=6)\n",
    "    sub_style   = ParagraphStyle(\"Sub\", parent=styles[\"Normal\"],\n",
    "                                 textColor=colors.grey, fontSize=10)\n",
    "    h2_style    = ParagraphStyle(\"H2\", parent=styles[\"Heading2\"],\n",
    "                                 textColor=TEAL, fontSize=13, spaceBefore=12)\n",
    "    body_style  = ParagraphStyle(\"Body\", parent=styles[\"Normal\"], fontSize=10, leading=14)\n",
    "\n",
    "    story.append(Paragraph(\"🥗 NutriRAG Pro — Nutrition Report\", title_style))\n",
    "    story.append(Paragraph(\n",
    "        f\"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}\", sub_style))\n",
    "    story.append(Spacer(1, 0.2*inch))\n",
    "\n",
    "    # ── Profile summary ──\n",
    "    p = session[\"profile\"]\n",
    "    tdee = calculate_tdee(p)\n",
    "    story.append(Paragraph(\"User Profile\", h2_style))\n",
    "    profile_data = [\n",
    "        [\"Name\", p[\"name\"], \"Age\", str(p[\"age\"])],\n",
