    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# TAB 3 ─ Tracker\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "btn_refresh   = widgets.Button(description=\"🔄 Refresh Tracker\", button_style=\"primary\",\n",
    "                                layout=widgets.Layout(width=\"180px\"))\n",
    "btn_gaps      = widgets.Button(description=\"🔍 Check Gaps\", button_style=\"warning\",\n",
    "                                layout=widgets.Layout(width=\"150px\"))\n",
    "btn_charts    = widgets.Button(description=\"📊 Show Charts\", button_style=\"success\",\n",
    "                                layout=widgets.Layout(width=\"150px\"))\n",
    "out_tracker   = widgets.Output()\n",
    "out_gaps      = widgets.Output()\n",
    "out_charts    = widgets.Output()\n",
    "\n",
    "def render_tracker():\n",
    "    totals = get_daily_totals()\n",
    "    t = calculate_tdee(session[\"profile\"])\n",
    "    target = t[\"target_calories\"]\n",
    "    eaten  = totals[\"calories\"]\n",
    "    pct    = min(int(eaten / target * 100), 100) if target > 0 else 0\n",
    "    bar_color = \"#d9534f\" if pct >= 90 else \"#1D9E75\"\n",
    "\n",
    "    # Meal log rows\n",
    "    if session[\"daily_log\"]:\n",
    "        rows = \"\".join([\n",
    "            f'<tr style=\"background:{\"white\" if i%2==0 else \"#f0f7ff\"}\">'\n",
    "            f'<td style=\"padding:5px 8px\">{m[\"time\"]}</td>'\n",
    "            f'<td style=\"padding:5px 8px\">{m[\"food_names\"][:50]}…</td>'\n",
    "            f'<td style=\"padding:5px 8px;text-align:center\">{m[\"nutrients\"].get(\"calories\",0):.0f}</td>'\n",
    "            f'<td style=\"padding:5px 8px;text-align:center\">{m[\"nutrients\"].get(\"protein_g\",0):.1f}g</td>'\n",
    "            f'</tr>'\n",
    "            for i, m in enumerate(session[\"daily_log\"])\n",
    "        ])\n",
    "        log_table = f\"\"\"\n",
    "        <table style=\"width:100%;border-collapse:collapse;font-size:13px;margin-top:10px\">\n",
    "          <tr style=\"background:#0f4c75;color:white\">\n",
    "            <th style=\"padding:5px 8px\">Time</th>\n",
    "            <th style=\"padding:5px 8px\">Foods</th>\n",
    "            <th style=\"padding:5px 8px\">Calories</th>\n",
    "            <th style=\"padding:5px 8px\">Protein</th>\n",
    "          </tr>{rows}\n",
    "        </table>\"\"\"\n",
    "    else:\n",
    "        log_table = '<p style=\"color:#888\">No meals logged yet.</p>'\n",
    "\n",
    "    with out_tracker:\n",
    "        clear_output()\n",
    "        display(HTML(f\"\"\"\n",
    "        <div style=\"font-family:sans-serif\">\n",
    "          <h4 style=\"color:#0f4c75;margin-bottom:6px\">📅 Today's Calorie Progress</h4>\n",
    "          <div style=\"background:#e0e0e0;border-radius:8px;height:22px;width:100%;overflow:hidden\">\n",
    "            <div style=\"background:{bar_color};width:{pct}%;height:100%;border-radius:8px;\n",
    "              transition:width 0.4s;display:flex;align-items:center;justify-content:center;\n",
    "              color:white;font-size:12px;font-weight:bold\">\n",
    "              {eaten:.0f} / {target} kcal ({pct}%)\n",
    "            </div>\n",
    "          </div>\n",
    "          <div style=\"display:flex;gap:12px;margin-top:12px\">\n",
    "            {_macro_card('💪 Protein', totals['protein_g'], 'g', t['target_protein_g'])}\n",
    "            {_macro_card('🌾 Carbs',   totals['carbs_g'],   'g', t['target_carbs_g'])}\n",
    "            {_macro_card('🥑 Fat',     totals['fat_g'],     'g', t['target_fat_g'])}\n",
    "            {_macro_card('🌿 Fiber',   totals['fiber_g'],   'g', WHO_DRV['fiber_g'])}\n",
    "          </div>\n",
    "          <h4 style=\"color:#0f4c75;margin-top:14px;margin-bottom:4px\">🍽️ Meal Log</h4>\n",
    "          {log_table}\n",
    "        </div>\"\"\"))\n",
    "\n",
    "def _macro_card(label, val, unit, target_val):\n",
    "    pct = min(int(val / target_val * 100), 100) if target_val else 0\n",
    "    return (f'<div style=\"flex:1;background:#f0f7ff;border-radius:8px;padding:10px;text-align:center\">'\n",
    "            f'<div style=\"font-size:12px;color:#666\">{label}</div>'\n",
    "            f'<div style=\"font-size:18px;font-weight:bold;color:#0f4c75\">{val:.1f}{unit}</div>'\n",
    "            f'<div style=\"font-size:11px;color:#888\">of {target_val}{unit} ({pct}%)</div>'\n",
    "            f'</div>')\n",
    "\n",
    "def on_refresh(b):  render_tracker()\n",
    "btn_refresh.on_click(on_refresh)\n",
    "\n",
    "def on_check_gaps(b):\n",
    "    gaps = check_deficiencies()\n",
    "    rows = \"\".join([\n",
    "        f'<tr style=\"background:{\"white\" if i%2==0 else \"#f0f7ff\"}\">' +\n",
    "        f'<td style=\"padding:4px 8px\">{g[\"nutrient\"].replace(\"_\",\" \").title()}</td>' +\n",
    "        f'<td style=\"padding:4px 8px;text-align:center\">{g[\"consumed\"]}</td>' +\n",
    "        f'<td style=\"padding:4px 8px;text-align:center\">{g[\"drv\"]}</td>' +\n",
    "        f'<td style=\"padding:4px 8px;text-align:center\">{g[\"pct\"]}%</td>' +\n",
    "        f'<td style=\"padding:4px 8px;text-align:center;font-weight:bold;color:'\n",
    "        + ({\"OK\":\"#1D9E75\",\"LOW\":\"#e67e22\",\"HIGH\":\"#d9534f\"}.get(g[\"status\"],\"#333\")) +\n",
    "        f'\">{g[\"status\"]}</td></tr>'\n",
    "        for i, g in enumerate(gaps)\n",
    "    ])\n",
    "    with out_gaps:\n",
    "        clear_output()\n",
    "        display(HTML(f\"\"\"\n",
    "        <div style=\"font-family:sans-serif;margin-top:8px\">\n",
    "          <b style=\"color:#0f4c75\">🔍 Nutrient Gap Analysis (vs WHO DRV)</b>\n",
    "          <table style=\"width:100%;border-collapse:collapse;font-size:12px;margin-top:6px\">\n",
    "            <tr style=\"background:#0f4c75;color:white\">\n",
    "              <th style=\"padding:4px 8px\">Nutrient</th>\n",
    "              <th style=\"padding:4px 8px\">Consumed</th>\n",
    "              <th style=\"padding:4px 8px\">DRV</th>\n",
    "              <th style=\"padding:4px 8px\">% DRV</th>\n",
    "              <th style=\"padding:4px 8px\">Status</th>\n",
    "            </tr>{rows}\n",
    "          </table>\n",
    "        </div>\"\"\"))\n",
    "btn_gaps.on_click(on_check_gaps)\n",
    "\n",
    "def on_show_charts(b):\n",
    "    totals = get_daily_totals()\n",
    "    t = calculate_tdee(session[\"profile\"])\n",
    "\n",
    "    # Chart 1 — Macro donut\n",
    "    prot_cal = totals[\"protein_g\"] * 4\n",
    "    carb_cal = totals[\"carbs_g\"]   * 4\n",
    "    fat_cal  = totals[\"fat_g\"]     * 9\n",
    "    fig1 = go.Figure(go.Pie(\n",
    "        labels=[\"Protein\",\"Carbs\",\"Fat\"],\n",
    "        values=[prot_cal, carb_cal, fat_cal],\n",
    "        hole=0.45,\n",
    "        marker_colors=[\"#0f4c75\",\"#1D9E75\",\"#f0a500\"],\n",
    "    ))\n",
    "    fig1.update_layout(title=\"Macro Calorie Split\", height=320,\n",
    "                       margin=dict(t=40,b=10,l=10,r=10))\n",
    "\n",
    "    # Chart 2 — Stacked bar: eaten vs remaining\n",
    "    eaten  = totals[\"calories\"]\n",
    "    remain = max(t[\"target_calories\"] - eaten, 0)\n",
    "    fig2 = go.Figure()\n",
    "    fig2.add_bar(x=[\"Calories\"], y=[eaten],  name=\"Eaten\",     marker_color=\"#1D9E75\")\n",
    "    fig2.add_bar(x=[\"Calories\"], y=[remain], name=\"Remaining\", marker_color=\"#cce8ff\")\n",
    "    fig2.update_layout(barmode=\"stack\", title=\"Calories: Eaten vs Remaining\",\n",
    "                       height=320, margin=dict(t=40,b=10,l=10,r=10))\n",
    "\n",
    "    # Chart 3 — Radar: micronutrient % of DRV\n",
    "    micro_keys = [\"vitamin_c_mg\",\"calcium_mg\",\"iron_mg\",\"fiber_g\",\"protein_g\"]\n",
    "    micro_labels = [\"Vitamin C\",\"Calcium\",\"Iron\",\"Fiber\",\"Protein\"]\n",
    "    micro_pcts = [\n",
    "        min(totals.get(k,0) / WHO_DRV.get(k,1) * 100, 150)\n",
    "        for k in micro_keys\n",
    "    ]\n",
    "    fig3 = go.Figure(go.Scatterpolar(\n",
    "        r=micro_pcts + [micro_pcts[0]],\n",
    "        theta=micro_labels + [micro_labels[0]],\n",
    "        fill=\"toself\", fillcolor=\"rgba(29,158,117,0.2)\",\n",
    "        line_color=\"#1D9E75\",\n",
    "    ))\n",
    "    fig3.update_layout(\n",
    "        polar=dict(radialaxis=dict(visible=True, range=[0,150])),\n",
    "        title=\"Micronutrient % of DRV\", height=320,\n",
    "        margin=dict(t=50,b=10,l=10,r=10)\n",
    "    )\n",
    "\n",
    "    with out_charts:\n",
    "        clear_output()\n",
    "        fig1.show()\n",
    "        fig2.show()\n",
    "        fig3.show()\n",
    "\n",
    "btn_charts.on_click(on_show_charts)\n",
    "\n",
    "tab3 = widgets.VBox([\n",
    "    HTML('<h3 style=\"color:#0f4c75;font-family:sans-serif;margin-bottom:4px\">📋 Daily Tracker</h3>'),\n",
    "    widgets.HBox([btn_refresh, btn_gaps, btn_charts],\n",
    "                 layout=widgets.Layout(gap=\"8px\", margin=\"4px 0\")),\n",
    "    out_tracker,\n",
    "    out_gaps,\n",
    "    out_charts,\n",
    "], layout=widgets.Layout(padding=\"16px\"))\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# TAB 4 ─ Export\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "btn_gen_pdf = widgets.Button(description=\"📄 Generate PDF Report\", button_style=\"primary\",\n",
    "                              layout=widgets.Layout(width=\"200px\", margin=\"12px 0\"))\n",
    "out_export  = widgets.Output()\n",
    "\n",
    "def on_gen_pdf(b):\n",
    "    with out_export:\n",
    "        clear_output()\n",
    "        display(HTML('<p style=\"font-family:sans-serif;color:#888\">Generating PDF…</p>'))\n",
    "    try:\n",
    "        fname = f\"nutrirag_report_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf\"\n",
    "        generate_pdf_report(fname)\n",
    "        with out_export:\n",
    "            clear_output()\n",
    "            display(HTML(f\"\"\"\n",
    "            <div style=\"background:#f0f7ff;border-radius:10px;padding:16px;font-family:sans-serif\">\n",
    "              <b style=\"color:#1D9E75;font-size:16px\">✅ Report Generated!</b><br><br>\n",
    "              📄 File saved as: <code style=\"background:#e0e0e0;padding:2px 6px;border-radius:4px\">{fname}</code><br><br>\n",
    "              <span style=\"color:#555\">The file is in your Colab working directory. \"\n",
    "              \"Use the Files panel (📁) on the left to download it.</span>\n",
    "            </div>\"\"\"))\n",
    "    except Exception as e:\n",
    "        with out_export:\n",
    "            clear_output()\n",
    "            display(HTML(f'<p style=\"color:red;font-family:sans-serif\">❌ Error: {e}</p>'))\n",
    "\n",
    "btn_gen_pdf.on_click(on_gen_pdf)\n",
    "\n",
    "tab4 = widgets.VBox([\n",
    "    HTML('<h3 style=\"color:#0f4c75;font-family:sans-serif;margin-bottom:4px\">📄 Export Report</h3>'),\n",
    "    HTML(\"\"\"\n",
    "    <div style=\"background:#f0f7ff;border-radius:10px;padding:16px;font-family:sans-serif;max-width:480px\">\n",
    "      <b style=\"color:#0f4c75\">What's included in your PDF:</b>\n",
    "      <ul style=\"margin-top:8px;color:#444;line-height:1.8\">\n",
    "        <li>👤 User profile & calculated TDEE targets</li>\n",
    "        <li>📊 Nutrient intake vs WHO Daily Reference Values</li>\n",
    "        <li>🍽️ Full meal log with timestamps & macros</li>\n",
    "        <li>⚠️ Deficiency & excess analysis with colour coding</li>\n",
    "        <li>📝 Professional formatting with colour headers</li>\n",
    "      </ul>\n",
    "    </div>\"\"\"),\n",
    "    btn_gen_pdf,\n",
    "    out_export,\n",
    "], layout=widgets.Layout(padding=\"16px\"))\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# Assemble tabbed app\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "app = widgets.Tab(children=[tab1, tab2, tab3, tab4])\n",
    "app.set_title(0, \"👤 Profile\")\n",
    "app.set_title(1, \"🔬 Analyze\")\n",
    "app.set_title(2, \"📋 Tracker\")\n",
    "app.set_title(3, \"📄 Export\")\n",
    "\n",
    "display(HTML(\"\"\"\n",
    "<div style=\"font-family:sans-serif;background:linear-gradient(135deg,#0f4c75,#1D9E75);\n",
    "  color:white;padding:16px 20px;border-radius:10px;margin-bottom:8px\">\n",
    "  <h2 style=\"margin:0\">🥗 NutriRAG Pro</h2>\n",
    "  <p style=\"margin:4px 0 0;opacity:0.85\">Multimodal Nutrition Analyzer · Powered by Gemini 2.0 Flash + ChromaDB</p>\n",
    "</div>\"\"\"))\n",
    "display(app)"
   ]
  }
 ]
}\n